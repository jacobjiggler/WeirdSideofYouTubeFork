<!DOCTYPE html>
<html>
<head>
  <title>Submit a Video — The Weird Side of YouTube</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/css/pure-min.css">
  <link rel="stylesheet" type="text/css" href="./css/newstyle.css">
  <link href="https://fonts.googleapis.com/css?family=Raleway:600" rel="stylesheet">
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</head>
<body>
  <div class="custom-menu-wrapper">
    <div class="pure-menu custom-menu">
      <a href="/" class="pure-menu-heading custom-menu-brand">Home</a>
      <a href="#" class="custom-menu-toggle" id="toggle"><s class="bar"></s><s class="bar"></s></a>
    </div>
    <div class="pure-menu pure-menu-horizontal pure-menu-scrollable custom-menu custom-menu-bottom custom-menu-tucked" id="tuckedMenu">
      <div class="custom-menu-screen"></div>
      <ul class="pure-menu-list">
        <li class="pure-menu-item"><a href="/about" class="pure-menu-link">About Us</a></li>
        <li class="pure-menu-item"><a href="/butwhy" class="pure-menu-link">But Why Though?</a></li>
        <li class="pure-menu-item"><a href="/submit" class="pure-menu-link">Submit a Video</a></li>
        <%if (user) { %>
          <%if (user.admin) { %>
            <li class="pure-menu-item"><a href="/admin" class="pure-menu-link">Admin Panel</a></li>
          <% } %>
          <li class="pure-menu-item"><a href="/history" class="pure-menu-link">View History</a></li>
          <li class="pure-menu-item"><a href="/logout" class="pure-menu-link">Logout</a></li>
          <li class="pure-menu-item"><a class="pure-menu-link custom-menu-brand"> Username: <%= user.username %> </a></li>
        <% } %>
        <%if (!user) { %>
          <li class="pure-menu-item"><a href="/login" class="pure-menu-link">Login</a></li>
        <% } %>
      </ul>
    </div>
  </div>
  <script>
  (function (window, document) {
    document.getElementById('toggle').addEventListener('click', function () {
      document.getElementById('tuckedMenu').classList.toggle('custom-menu-tucked');
      document.getElementById('toggle').classList.toggle('x');
    });
  })(this, this.document);
  </script>

  <br><br>
  <div id="textbox">
    <div id="title"><h1>Submit a Video</h1></div>

    <% if (submitted) { %>
      <div id="textbody">
        <p>Thanks! Your suggestion is in the queue and an admin will review it soon.</p>
        <p><a href="/submit" style="color:#8ec7ff;">Submit another</a></p>
      </div>
    <% } else { %>
      <div id="textbody">
        <p>Found something gloriously weird? Paste a YouTube <strong>video</strong> or <strong>playlist</strong> link below. Approved suggestions get added to the pool.</p>
        <% if (error) { %>
          <p style="color:#ff8a8a; font-weight:bold;"><%= error %></p>
        <% } %>
      </div>

      <form method="POST" action="/submit" style="max-width:560px; margin:0 auto; padding:10px 0 20px;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <!-- honeypot: hidden from real users; bots that fill it get silently dropped -->
        <div style="position:absolute; left:-9999px; top:-9999px;" aria-hidden="true">
          <label>Leave this field empty
            <input type="text" name="website" tabindex="-1" autocomplete="off">
          </label>
        </div>

        <input type="text" name="url" required
               placeholder="https://www.youtube.com/watch?v=...  or  /playlist?list=..."
               style="width:100%; box-sizing:border-box; padding:10px; font-size:14px; border:1px solid #555; border-radius:4px; margin-bottom:12px;">

        <div class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" style="margin-bottom:12px;"></div>

        <button type="submit"
                style="background-image:linear-gradient(to bottom,#707070,#333333); color:#fff; text-transform:uppercase; font-weight:700; font-size:16px; padding:10px 30px; border:solid #000 2px; border-radius:8px; cursor:pointer;">
          Submit
        </button>
      </form>
    <% } %>
  </div>
</body>
</html>

<!DOCTYPE html>
<html>
<head>
  <title>Stats — Admin</title>
  <link rel="stylesheet" href="<%= assetUrl('/css/pure-min.css') %>">
  <link rel="stylesheet" type="text/css" href="<%= assetUrl('/css/newstyle.css') %>">
</head>
<body>

  <div class="custom-menu-wrapper">
    <div class="pure-menu custom-menu">
      <a href="/" class="pure-menu-heading custom-menu-brand"> Home</a>
      <a href="#" class="custom-menu-toggle" id="toggle"><s class="bar"></s><s class="bar"></s></a>
    </div>
    <div class="pure-menu pure-menu-horizontal pure-menu-scrollable custom-menu custom-menu-bottom custom-menu-tucked" id="tuckedMenu">
      <div class="custom-menu-screen"></div>
      <ul class="pure-menu-list">
        <li class="pure-menu-item"><a href="/admin" class="pure-menu-link">Admin Panel</a></li>
        <li class="pure-menu-item"><a href="/admin/submissions" class="pure-menu-link">Submissions</a></li>
        <li class="pure-menu-item"><a href="/admin/stats" class="pure-menu-link">Stats</a></li>
        <li class="pure-menu-item"><a href="/logout" class="pure-menu-link">Logout</a></li>
      </ul>
    </div>
  </div>
  <script>
  (function (window, document) {
    document.getElementById('toggle').addEventListener('click', function () {
      document.getElementById('tuckedMenu').classList.toggle('custom-menu-tucked');
      document.getElementById('toggle').classList.toggle('x');
    });
  })(this, this.document);
  </script>

  <div id="title" style="margin-top:16px;"><h1>Engagement stats</h1></div>
  <div id="textbody">
    <p style="opacity:0.7; font-size:13px;">
      "Session" = the existing session cookie (up to 7 days), same one used for video dedup —
      not a single sitting. A visitor who returns within that window counts as the same session.
    </p>
  </div>

  <div style="display:flex; gap:16px; flex-wrap:wrap; margin:16px 0;">
    <div style="background:#1e1e1e; border-radius:8px; padding:16px 20px; min-width:200px;">
      <div style="font-size:13px; opacity:0.7;">Avg videos watched per session</div>
      <div style="font-size:28px; font-weight:bold;"><%= avgVideosWatched.toFixed(2) %></div>
      <div style="font-size:12px; opacity:0.6;">across <%= watchedSessionCount %> session(s) that watched at least one</div>
    </div>

    <div style="background:#1e1e1e; border-radius:8px; padding:16px 20px; min-width:200px;">
      <div style="font-size:13px; opacity:0.7;">Landed but never clicked Get Weird</div>
      <div style="font-size:28px; font-weight:bold;"><%= bouncedCount %> / <%= landedCount %></div>
      <div style="font-size:12px; opacity:0.6;"><%= bounceRate.toFixed(1) %>% bounce rate</div>
    </div>
  </div>

  <div id="title" style="margin-top:24px;"><h2>Videos sessions end on most often</h2></div>
  <div id="textbody">
    <p style="opacity:0.7; font-size:13px;">
      The last video played in a session, as a proxy for "what they were watching when they left" —
      there's no real signal for a closed tab, so this is the closest approximation.
    </p>
  </div>

  <% if (!topEndingVideos.length) { %>
    <div id="textbody"><p>No data yet.</p></div>
  <% } else { %>
  <table cellspacing="5">
    <tr>
      <td class="header-cell">Count</td>
      <td class="header-cell">Title</td>
      <td class="header-cell">Video</td>
    </tr>
    <% topEndingVideos.forEach(function (v) { %>
    <tr>
      <td class="data-cell"><%= v.count %></td>
      <td class="data-cell"><%= v.title || '(title unavailable)' %></td>
      <td class="data-cell"><a href="https://www.youtube.com/watch?v=<%= v.videoID %>" target="_blank" rel="noopener noreferrer" style="color:#8ec7ff;"><%= v.videoID %></a></td>
    </tr>
    <% }); %>
  </table>
  <% } %>

</body>
</html>

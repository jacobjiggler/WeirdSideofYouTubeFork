<!DOCTYPE html>
<html>
<head>
<title>Video History</title>
<link rel="stylesheet" href="<%= assetUrl('/css/pure-min.css') %>">
<link rel="stylesheet" type="text/css" href="<%= assetUrl('/css/newstyle.css') %>">
</head>

<body>

  <div class="custom-menu-wrapper">
    <div class="pure-menu custom-menu">
      <a href="/" class="pure-menu-heading custom-menu-brand">Home</a>
      <a href="#" class="custom-menu-toggle" id="toggle"><s class="bar"></s><s class="bar"></s></a>
    </div>
    <div class="pure-menu pure-menu-horizontal pure-menu-scrollable custom-menu custom-menu-bottom custom-menu-tucked" id="tuckedMenu">
      <div class="custom-menu-screen"></div>
      <ul class="pure-menu-list">
        <li class="pure-menu-item"><a href="/about" class="pure-menu-link">About Us</a></li>
        <li class="pure-menu-item"><a href="/butwhy" class="pure-menu-link">But Why Though?</a></li>
        <li class="pure-menu-item"><a href="/submit" class="pure-menu-link">Submit a Video</a></li>
        <%if (user) { %>
          <%if (user.admin) { %>
            <li class="pure-menu-item"><a href="/admin" class="pure-menu-link">Admin Panel</a></li>
          <% } %>
          <li class="pure-menu-item"><a href="/history" class="pure-menu-link">View History</a></li>
          <li class="pure-menu-item"><a href="/logout" class="pure-menu-link">Logout</a></li>
          <li class="pure-menu-item"><a class="pure-menu-link custom-menu-brand"> Username: <%= user.username %></a></li>
        <% } %>
        <%if (!user) { %>
          <li class="pure-menu-item"><a href="/login" class="pure-menu-link">Login</a></li>
          <% } %>
      </ul>
    </div>
  </div>
  <script>
  (function (window, document) {
  document.getElementById('toggle').addEventListener('click', function (e) {
      document.getElementById('tuckedMenu').classList.toggle('custom-menu-tucked');
      document.getElementById('toggle').classList.toggle('x');
  });
  })(this, this.document);
  </script>

<table id="videoTable" cellspacing="5" class="table">
	<tr id="tableheader">
    <td class = "header-cell"> ID</td>
	  <td class = "header-cell">Thumbnail</td>
	  <td class = "header-cell">Title</td>
	  <td class = "header-cell"> Date</td>
	  <td class = "header-cell" style="width:280px;">User Agent</td>
 	</tr>
</table>

<script type="text/javascript">
	// Build the history table with native DOM APIs (no jQuery). Cells use
	// textContent / encodeURIComponent so nothing is injected as raw HTML, and
	// the title cell is captured in a closure rather than re-queried by id
	// (YouTube ids can start with a digit, which breaks '#id' selectors).
	function loadNewTable() {
		var table = document.getElementById('videoTable');
		fetch('/api/gethistory/', { credentials: 'same-origin' })
			.then(function (res) { return res.json(); })
			.then(function (videos) {
				videos.forEach(function (video) {
					var tr = document.createElement('tr');
					tr.className = 'videoRow';

					var linkTd = document.createElement('td');
					linkTd.className = 'data-cell';
					var a = document.createElement('a');
					a.href = 'https://www.youtube.com/watch?v=' + encodeURIComponent(video.videoID);
					a.textContent = video.videoID;
					linkTd.appendChild(a);
					tr.appendChild(linkTd);

					var thumbTd = document.createElement('td');
					thumbTd.className = 'data-cell';
					var img = document.createElement('img');
					img.src = 'https://i.ytimg.com/vi/' + encodeURIComponent(video.videoID) + '/default.jpg';
					thumbTd.appendChild(img);
					tr.appendChild(thumbTd);

					var titleTd = document.createElement('td');
					titleTd.className = 'data-cell';
					tr.appendChild(titleTd);

					var dateTd = document.createElement('td');
					dateTd.className = 'data-cell';
					dateTd.textContent = video.time;
					tr.appendChild(dateTd);

					var uaTd = document.createElement('td');
					uaTd.className = 'data-cell';
					uaTd.style.cssText = 'width:280px; white-space:normal; word-break:break-all; font-size:11px !important; line-height:14px !important;';
					uaTd.textContent = video.userAgent || '—';
					tr.appendChild(uaTd);

					table.appendChild(tr);

					fetch('/api/getVidInfo/' + encodeURIComponent(video.videoID))
						.then(function (res) { return res.json(); })
						.then(function (data) {
							if (data.items && data.items[0]) {
								titleTd.textContent = data.items[0].snippet.title;
							}
						})
						.catch(function () {});
				});
			})
			.catch(function (error) { console.error(error); });
	}

	loadNewTable();
</script>

</body>
</html>

<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>The Weird Side of YouTube — Random Weird Videos</title>
  <meta name="description" content="Click one button and dive into the weird side of YouTube — a hand-picked stream of strange, surreal, and hilarious videos served up at random.">
  <link rel="canonical" href="https://weirdtube.wtf/">

  <!-- Open Graph (Facebook, Discord, iMessage, etc.) -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://weirdtube.wtf/">
  <meta property="og:title" content="The Weird Side of YouTube">
  <meta property="og:description" content="Hit 'Get Weird' and get a random strange YouTube video. Endlessly.">
  <meta property="og:image" content="https://weirdtube.wtf/og-image.png">

  <!-- Twitter / X card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="The Weird Side of YouTube">
  <meta name="twitter:description" content="Hit 'Get Weird' and get a random strange YouTube video. Endlessly.">
  <meta name="twitter:image" content="https://weirdtube.wtf/og-image.png">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="https://unpkg.com/purecss@0.6.2/build/pure-min.css" integrity="sha384-UQiGfs9ICog+LwheBSRCt1o5cbyKIHbwjWscjemyBMT9YCUMZffs6UqUTd0hObXD" crossorigin="anonymous">
  <link rel="stylesheet" type="text/css" href="./css/WeirdStyle.css">
  <link href="https://fonts.googleapis.com/css?family=Damion" rel="stylesheet">
</head>

<body>

  <div id="navbar">
    <button id="navToggle" class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">&#9776;</button>
    <ul id="navMenu">
      <li><a href="/">Home</a></li>
      <li><a href="/about">About Us</a></li>
      <li><a href="/butwhy">But Why Though?</a></li>
      <%if (user) { %>
        <%if (user.admin) { %>
          <li><a href="/admin">Admin Panel</a></li>
        <% } %>
        <li><a href="/history">View History</a></li>
        <li><a href="/logout">Logout</a></li>
        <li><p>Username: <%= user.username %></p></li>
      <% } %>
      <%if (!user) { %>
        <li><a href="/login">Login</a></li>
      <% } %>
    </ul>
  </div>

  <div class="titlebox">
    <span class="t1">The Weird Side of YouTube</span>
  </div>

  <!-- Splash: visible on load -->
  <div id="splash">
    <div class="gobutton" id="gobutton">
      <span>Get Weird</span>
    </div>
  </div>

  <!-- Player: hidden until Get Weird is clicked -->
  <div id='youtube-player-container' style="display:none;">
    <div id="player-wrapper">
      <div id='youtube-player'></div>
    </div>
    <div id="playDiv">
      <a id="playerbutton" class="playerbutton">
        <span>Next</span>
      </a>
      <a id="sharebutton" class="playerbutton" role="button" aria-label="Share this video">
        <span>Share</span>
      </a>
    </div>
  </div>

  <script type="text/javascript" src="videos.js"></script>
  <script>
    document.getElementById('gobutton').addEventListener('click', function() {
      document.getElementById('splash').style.display = 'none';
      document.getElementById('youtube-player-container').style.display = 'block';
      playNextVid();
    });

    // Hamburger toggle for the mobile nav
    var navToggle = document.getElementById('navToggle');
    var navMenu = document.getElementById('navMenu');
    navToggle.addEventListener('click', function() {
      var open = navMenu.classList.toggle('open');
      navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    // Share the current video (native share sheet on mobile, clipboard fallback)
    document.getElementById('sharebutton').addEventListener('click', function() {
      var id = window.currentVidId;
      var url = id ? ('https://www.youtube.com/watch?v=' + id) : 'https://weirdtube.wtf/';
      if (navigator.share) {
        navigator.share({ title: 'The Weird Side of YouTube', url: url }).catch(function() {});
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(url).then(function() { alert('Link copied: ' + url); });
      } else {
        window.prompt('Copy this link:', url);
      }
    });
  </script>

</body>
</html>

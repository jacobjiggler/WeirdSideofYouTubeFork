# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Your YouTube Data API v3 key (get one at https://console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Secrets used to sign sessions and cookies. Generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=generate_a_long_random_value
COOKIE_SECRET=generate_a_long_random_value

# Cloudflare Turnstile keys for the /submit form captcha (optional).
# If unset, Cloudflare's always-pass TEST keys are used so the form still works
# in development. Set real keys from the Cloudflare dashboard for production.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
